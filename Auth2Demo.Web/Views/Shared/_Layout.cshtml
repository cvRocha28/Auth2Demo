@using Auth2Demo.Web.Services.Branding
@inject IBrandingResolver BrandingResolver
@{
    var branding = await BrandingResolver.ResolveAsync(Context);
    var titleSuffix = string.IsNullOrWhiteSpace(branding.TenantName) ? T["TitleSuffix"].Value : branding.TenantName;
    var isAuthenticationExperience =
        Context.Request.Path.StartsWithSegments("/Account/Login", StringComparison.OrdinalIgnoreCase) ||
        Context.Request.Path.StartsWithSegments("/Account/Register", StringComparison.OrdinalIgnoreCase) ||
        Context.Request.Path.StartsWithSegments("/connect/authorize", StringComparison.OrdinalIgnoreCase) ||
        Context.Request.Path.StartsWithSegments("/Authorization", StringComparison.OrdinalIgnoreCase) ||
        (ViewData["HideShellHeader"] as bool? == true);
}
<!doctype html>
<html lang='@T["HtmlLang"].Value' data-theme="@branding.Theme.ToLowerInvariant()">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - @titleSuffix</title>
    @if (!string.IsNullOrWhiteSpace(branding.FaviconUrl))
    {
        <link rel="icon" href="@branding.FaviconUrl" />
    }
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <link rel="stylesheet" href="@($"/branding/theme.css{Context.Request.QueryString}")" />
</head>
<body class='@(isAuthenticationExperience ? "auth-experience-body" : string.Empty)'>
@if (User.Identity?.IsAuthenticated == true && !isAuthenticationExperience)
{
    <header class="topbar">
        <a class="brand" asp-controller="Home" asp-action="Index">
            <span class="brand-mark">
                @if (branding.HasLogo)
                {
                    <img src="@branding.LogoUrl" alt="@branding.TenantName" />
                }
                else
                {
                    <i class="bi bi-shield-lock" aria-hidden="true"></i>
                }
            </span>
            <span>@branding.TenantName</span>
        </a>
        <nav>
            <a class="nav-link" asp-controller="Perfil" asp-action="Index">@T["Profile"]</a>
            <a class="nav-link" asp-controller="Account" asp-action="ManageMfa">@T["Mfa"]</a>
            @if (User.IsInRole("admin"))
            {
                <a class="nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">@T["Admin"]</a>
            }
            <form asp-controller="Account" asp-action="Logout" method="post" class="inline">
                <button class="link-button" type="submit">@T["Logout"]</button>
            </form>
        </nav>
    </header>
}
<main class='@(isAuthenticationExperience ? "auth-experience-main" : "container")'>@RenderBody()</main>
<script src="~/js/site.js" asp-append-version="true" defer></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
