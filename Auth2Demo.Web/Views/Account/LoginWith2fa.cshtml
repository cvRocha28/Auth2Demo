@model Auth2Demo.Web.Models.Account.TwoFactorLoginViewModel
@{
    ViewData["Title"] = T["TwoFactorAuthentication"].Value;
}

<section class="auth-page">
    <div class="auth-card">
        <span class="eyebrow">@T["Security"]</span>
        <h1>@T["TextAutenticacaoEmDuasEtapas"]</h1>
        <p class="muted">@T["TextDigiteOCodigoDe6DigitosGeradoNo"]</p>

        <form asp-action="LoginWith2fa" method="post" class="form-stack">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ReturnUrl" />
            <input type="hidden" asp-for="RememberMe" />

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <label asp-for="Code"></label>
            <input asp-for="Code" autocomplete="one-time-code" inputmode="numeric" class="form-control" placeholder="000000" />
            <span asp-validation-for="Code" class="text-danger"></span>

            <label class="check-row">
                <input asp-for="RememberMachine" />
                <span>@T["ConfiarNesteDispositivo"]</span>
            </label>

            <button type="submit" class="btn btn-primary">@T["ValidateCode"]</button>
        </form>

        <p class="mt-3">
            <a asp-action="LoginWithRecoveryCode" asp-route-returnUrl="@Model.ReturnUrl">@T["TextUsarCodigoDeRecuperacao"]</a>
        </p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
