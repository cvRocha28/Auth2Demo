@model ForgotPasswordViewModel
@{
    ViewData["Title"] = T["ForgotPasswordTitle"].Value;
}

<div class="auth-card form-card">
    <div class="auth-header">
        <h1>@T["ForgotPasswordTitle"]</h1>
        <p>@T["ForgotPasswordDescription"]</p>
    </div>

    <form method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ReturnUrl" />
        <div asp-validation-summary="ModelOnly" class="validation"></div>
        <div class="form-row">
            <label asp-for="Login">@T["UsernameOrEmail"]</label>
            <div class="input-wrap"><span class="input-icon"><i class="bi bi-person-badge" aria-hidden="true"></i></span><input class="with-icon" asp-for="Login" autocomplete="username" /></div>
            <span asp-validation-for="Login"></span>
        </div>
        <button class="btn btn-block" type="submit">@T["SendPasswordResetLink"]</button>
    </form>

    <p class="form-footer"><a asp-action="Login" asp-route-returnUrl="@Model.ReturnUrl">@T["BackToLogin"]</a></p>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
