@model Auth2Demo.Web.Models.Account.MfaSetupViewModel
@{
    ViewData["Title"] = T["TextAutenticacaoEmDuasEtapas"].Value;
}

<section class="mfa-page">
    <div class="mfa-header">
        <div>
            <span class="eyebrow">@T["MySecurity"]</span>
            <h1>@T["TextAutenticacaoEmDuasEtapas"]</h1>
            <p>@T["TextProtejaLoginsComUsuarioESenhaUsandoUm"]</p>
        </div>
        <span class="status-pill @(Model.IsTwoFactorEnabled ? "on" : "off")">
            @(Model.IsTwoFactorEnabled ? T["MfaActive"].Value : T["MfaInactive"].Value)
        </span>
    </div>

    @if (TempData["Success"] is not null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] is not null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="mfa-grid">
        <div class="mfa-card qr-card">
            <h2>@T["Text1EscaneieOQrCode"]</h2>
            <p>@T["TextAbraMicrosoftAuthenticatorGoogleAuthenticatorAuthy1passwordOu"]</p>

            <img class="qr-code" src="@Model.QrCodeDataUrl" alt="QR Code MFA" />

            <details>
                <summary>@T["TextNaoConsegueEscanear"]</summary>
                <p>@T["TextDigiteEstaChaveManualmenteNoAplicativo"]</p>
                <code class="shared-key">@Model.SharedKey</code>
            </details>
        </div>

        <div class="mfa-card">
            <h2>@T["Text2ConfirmeOCodigo"]</h2>
            <p>@T["TextDepoisDeEscanearInformeOCodigoDe6"]</p>

            <form asp-action="EnableAuthenticator" method="post" class="form-stack">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <label asp-for="Code"></label>
                <input asp-for="Code" class="form-control" inputmode="numeric" autocomplete="one-time-code" placeholder="000000" />
                <span asp-validation-for="Code" class="text-danger"></span>

                <button type="submit" class="btn btn-primary">@T["EnableMfa"]</button>
            </form>

            <div class="action-row">
                <form asp-action="GenerateRecoveryCodes" method="post">
                    @Html.AntiForgeryToken()
                    @if (Model.IsTwoFactorEnabled)
                    {
                        <button type="submit" class="btn btn-secondary">@T["GenerateNewCodes"]</button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-secondary" disabled>@T["GenerateNewCodes"]</button>
                    }
                </form>
                <form asp-action="ResetAuthenticator" method="post" data-confirm="@T["TextIssoVaiDesabilitarOMfaAtualEGerar"]">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-secondary">@T["ResetQrCode"]</button>
                </form>
                <form asp-action="DisableMfa" method="post" data-confirm="@T["TextDesabilitarMfaReduzASegurancaDaContaContinuar"]">
                    @Html.AntiForgeryToken()
                    @if (Model.IsTwoFactorEnabled)
                    {
                        <button type="submit" class="btn btn-danger">@T["DisableMfa"]</button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-danger" disabled>@T["DisableMfa"]</button>
                    }
                </form>
            </div>
        </div>
    </div>

    <div class="mfa-card mt-4">
        <h2>@T["Status"]</h2>
        <div class="status-grid">
            <div><strong>@T["AplicativoAutenticador"]</strong><span>@(Model.HasAuthenticator ? T["Configured"] : T["NotConfigured"])</span></div>
            <div><strong>@T["Mfa"]</strong><span>@(Model.IsTwoFactorEnabled ? T["RequiredForLocalLogin"] : T["Disabled"])</span></div>
            <div><strong>@T["TextCodigosRestantes"]</strong><span>@Model.RecoveryCodesLeft</span></div>
        </div>
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/account-managemfa.css" asp-append-version="true" />
}
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
