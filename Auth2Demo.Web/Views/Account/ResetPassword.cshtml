@model ResetPasswordViewModel
@{
    ViewData["Title"] = T["ResetPassword"].Value;
}

<div class="auth-card form-card">
    <div class="auth-header">
        <h1>@T["ResetPassword"]</h1>
        <p>@T["ResetPasswordDescription"]</p>
    </div>

    <form method="post">
        <input type="hidden" asp-for="Email" />
        <input type="hidden" asp-for="Code" />
        <div asp-validation-summary="ModelOnly" class="validation"></div>
        <div class="form-row">
            <label asp-for="Password">@T["NewPassword"]</label>
            <div class="input-wrap"><span class="input-icon"><i class="bi bi-key" aria-hidden="true"></i></span><input class="with-icon" asp-for="Password" autocomplete="new-password" /></div>
            <span asp-validation-for="Password"></span>
        </div>
        <div class="form-row">
            <label asp-for="ConfirmPassword">@T["ConfirmNewPassword"]</label>
            <div class="input-wrap"><span class="input-icon"><i class="bi bi-key" aria-hidden="true"></i></span><input class="with-icon" asp-for="ConfirmPassword" autocomplete="new-password" /></div>
            <span asp-validation-for="ConfirmPassword"></span>
        </div>
        <button class="btn btn-block" type="submit">@T["SaveNewPassword"]</button>
    </form>

    <p class="form-footer"><a asp-action="Login">@T["BackToLogin"]</a></p>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
