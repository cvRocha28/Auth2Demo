@model PasswordResetSentViewModel
@{
    ViewData["Title"] = T["PasswordResetSentTitle"].Value;
}

<div class="auth-card form-card">
    <div class="auth-header">
        <h1>@T["PasswordResetSentTitle"]</h1>
        <p>@string.Format(T["PasswordResetSentDescription"].Value, Model.Email)</p>
    </div>

    <div class="alert">
        @T["TemporaryPasswordResetLinkNotice"]
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ResetLink))
    {
        <a class="btn btn-block" href="@Model.ResetLink">@T["ResetPassword"]</a>

        <div class="form-row">
            <label>@T["PasswordResetLink"]</label>
            <input value="@Model.ResetLink" readonly />
        </div>
    }
    else
    {
        <div class="validation">@T["PasswordResetGenericNoLink"]</div>
    }

    <p class="form-footer"><a asp-action="Login">@T["BackToLogin"]</a></p>
</div>
