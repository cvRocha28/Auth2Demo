@using Auth2Demo.Web.Models.Account
@model LoginViewModel

@{
    ViewData["Title"] = T["Login"].Value;
    var externalProviders = Model.ExternalProviders;
}

<div class="auth-card form-card">
    <div class="auth-tabs">
        <a class="auth-tab active" asp-action="Login">@T["Login"]</a>
        <a class="auth-tab" asp-action="Register">@T["CreateAccount"]</a>
    </div>

    <div class="auth-header">
        <div class="auth-badge">🔐</div>
        <h1>@T["Login"]</h1>
        <p>@T["TextAcesseComSeuEMailESenhaPara"]</p>
    </div>

    @if (TempData["Success"] is not null)
    {
        <div class="alert success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] is not null)
    {
        <div class="alert">@TempData["Error"]</div>
    }

    <form method="post" class="auth-form">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="ReturnUrl" />

        <div asp-validation-summary="ModelOnly" class="validation"></div>

        @if (Model.ShowResendEmailConfirmation)
        {
            <div class="confirm-email-panel">
                <div class="confirm-email-icon">📩</div>

                <div class="confirm-email-content">
                    <strong>@T["EmailNotConfirmed"]</strong>
                    <p>@T["TemporaryConfirmationLinkNotice"]</p>

                    <div class="confirm-email-actions">
                        <a class="btn btn-outline btn-small"
                           asp-action="EmailConfirmationSent"
                           asp-route-email="@Model.Email">
                            @T["ResendConfirmationEmail"]
                        </a>

                        @if (ViewData["EmailConfirmationLink"] is string confirmationLink && !string.IsNullOrWhiteSpace(confirmationLink))
                        {
                            <a class="btn btn-small"
                               href="@confirmationLink">
                                @T["ConfirmEmail"]
                            </a>
                        }
                    </div>

                    @if (ViewData["EmailConfirmationLink"] is string debugConfirmationLink && !string.IsNullOrWhiteSpace(debugConfirmationLink))
                    {
                        <div class="confirmation-debug-link">
                            <label>@T["TemporaryConfirmationLink"]</label>
                            <input value="@debugConfirmationLink" readonly />
                        </div>
                    }
                </div>
            </div>
        }

        <div class="form-row">
            <label asp-for="Email">@T["Email"]</label>
            <div class="input-wrap">
                <span class="input-icon">✉</span>
                <input class="with-icon"
                       asp-for="Email"
                       placeholder="admin@auth2demo.local"
                       autocomplete="username" />
            </div>
            <span asp-validation-for="Email"></span>
        </div>

        <div class="form-row">
            <label asp-for="Password">@T["Password"]</label>
            <div class="input-wrap">
                <span class="input-icon">🔑</span>
                <input class="with-icon"
                       asp-for="Password"
                       placeholder='@T["DigiteSuaSenha"].Value'
                       autocomplete="current-password" />
            </div>
            <span asp-validation-for="Password"></span>
        </div>

        <div class="login-options-row">
            <label class="check">
                <input asp-for="RememberMe" />
                <span>@T["LembrarAcesso"]</span>
            </label>

            <a class="forgot-password-link"
               asp-action="ForgotPassword">
                @T["ForgotPasswordQuestion"]
            </a>
        </div>

        <button class="btn btn-block" type="submit">@T["Login"]</button>
    </form>

    @if (externalProviders.Count > 0)
    {
        <div class="external-login-divider">
            <span>@T["OuContinueCom"]</span>
        </div>

        <div class="external-login-list">
            @foreach (var provider in externalProviders)
            {
                <form asp-controller="Account" asp-action="ExternalLogin" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="provider" value="@provider.Scheme" />
                    <input type="hidden" name="returnUrl" value="@(Model?.ReturnUrl)" />

                    <button class="btn btn-outline btn-block external-btn" type="submit">
                        <span class="provider-dot">@provider.DisplayName.Substring(0, 1)</span>
                        @provider.ButtonText
                    </button>
                </form>
            }
        </div>
    }

    <p class="form-footer">
        @T["TextNaoTemUmaConta"]
        <a asp-action="Register">@T["CreateAccount"]</a>
    </p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}