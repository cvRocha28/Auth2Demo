@using Auth2Demo.Web.Services.Branding
@inject IBrandingResolver BrandingResolver
@model Auth2Demo.Web.Models.Authorization.ConsentViewModel

@{
    ViewData["Title"] = T["TextAutorizarAplicacao"].Value;
    ViewData["HideShellHeader"] = true;
    var branding = await BrandingResolver.ResolveAsync(Context);

    var scopes = (Model.Scope ?? string.Empty)
        .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .ToArray();

    var authorizeUrl = $"{Context.Request.PathBase}/connect/authorize";
    var returnUrl = $"{Context.Request.PathBase}{Context.Request.Path}{Context.Request.QueryString}";
    var clientId = Context.Request.Query["client_id"].ToString();
    var redirectUri = Context.Request.Query["redirect_uri"].ToString();
    var responseType = Context.Request.Query["response_type"].ToString();
    var responseMode = Context.Request.Query["response_mode"].ToString();
    var codeChallengeMethod = Context.Request.Query["code_challenge_method"].ToString();
    var hasPkce = !string.IsNullOrWhiteSpace(Context.Request.Query["code_challenge"].ToString());
    var requestedAtUtc = DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm 'UTC'");
    var appName = string.IsNullOrWhiteSpace(Model.ApplicationName) ? clientId : Model.ApplicationName;
    var appInitials = string.Join("", appName.Split(new[] { ' ', '-', '_' }, StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => x[0])).ToUpperInvariant();
    if (string.IsNullOrWhiteSpace(appInitials))
    {
        appInitials = "APP";
    }

    string GetScopeTitle(string scope) => scope.ToLowerInvariant() switch
    {
        "openid" => "Sign you in",
        "profile" => "Read your basic profile",
        "email" => "Read your email address",
        "roles" => "Read your application roles",
        "offline_access" => "Maintain access when you are offline",
        _ => $"Access {scope}"
    };

    string GetScopeDescription(string scope) => scope.ToLowerInvariant() switch
    {
        "openid" => "Allows this application to confirm your identity using OpenID Connect.",
        "profile" => "Allows access to basic profile information such as name and user identifier.",
        "email" => "Allows access to your email address and email verification status.",
        "roles" => "Allows the application to receive your assigned authorization roles.",
        "offline_access" => "Allows refresh tokens so the application can keep you signed in securely.",
        _ => "Allows access to a custom permission configured for this application."
    };

    string GetScopeIcon(string scope) => scope.ToLowerInvariant() switch
    {
        "openid" => "bi-person-check",
        "profile" => "bi-person-vcard",
        "email" => "bi-envelope-check",
        "roles" => "bi-shield-check",
        "offline_access" => "bi-arrow-repeat",
        _ => "bi-key"
    };
}

<section class="consent-pro-page">
    <div class="consent-pro-shell">
        <div class="consent-pro-card">
            <div class="consent-pro-hero">
                <div class="consent-brand-block">
                    <div class="consent-app-logo" aria-hidden="true">
                        @if (branding.HasLogo)
                        {
                            <img src="@branding.LogoUrl" alt="@branding.TenantName" />
                        }
                        else
                        {
                            @appInitials
                        }
                    </div>
                    <div>
                        <div class="consent-pro-badges">
                            <span class="consent-pro-badge"><i class="bi bi-shield-lock" aria-hidden="true"></i> OpenID Connect</span>
                            <span class="consent-pro-badge is-success"><i class="bi bi-patch-check-fill" aria-hidden="true"></i> Registered client</span>
                        </div>
                        <h1>Authorize application</h1>
                        <p class="consent-pro-subtitle">
                            <strong>@appName</strong> wants permission to access your @branding.TenantName account.
                        </p>
                    </div>
                </div>
            </div>

            <div class="consent-pro-content">
                <main class="consent-pro-main">
                    <section class="consent-section-card">
                        <div class="consent-section-header">
                            <div>
                                <span class="consent-section-kicker">Requested access</span>
                                <h2>Permissions requested by this application</h2>
                            </div>
                            <span class="consent-count">@scopes.Length permission@(scopes.Length == 1 ? "" : "s")</span>
                        </div>

                        <div class="consent-permissions-list">
                            @foreach (var scope in scopes)
                            {
                                <article class="consent-permission-item">
                                    <div class="consent-permission-icon"><i class="bi @GetScopeIcon(scope)" aria-hidden="true"></i></div>
                                    <div class="consent-permission-copy">
                                        <strong>@GetScopeTitle(scope)</strong>
                                        <span>@GetScopeDescription(scope)</span>
                                        <code>@scope</code>
                                    </div>
                                </article>
                            }
                        </div>
                    </section>

                    <section class="consent-security-note">
                        <div class="consent-security-icon"><i class="bi bi-info-circle" aria-hidden="true"></i></div>
                        <div>
                            <strong>Review before continuing</strong>
                            <p>
                                If you allow access, Auth2Demo will redirect you back to the requesting application.
                                Your decision will be saved for this app while consent remains valid.
                            </p>
                        </div>
                    </section>

                    <div class="consent-actions-pro">
                        <form method="post" action="@authorizeUrl">
                            @Html.AntiForgeryToken()

                            @foreach (var item in Context.Request.Query)
                            {
                                foreach (var value in item.Value)
                                {
                                    <input type="hidden" name="@item.Key" value="@value" />
                                }
                            }

                            <button type="submit" class="consent-btn consent-btn-primary" name="accept" value="true">
                                <i class="bi bi-check2-circle" aria-hidden="true"></i>
                                Allow and continue
                            </button>
                        </form>

                        <form method="post" asp-controller="Authorization" asp-action="Deny">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="returnUrl" value="@returnUrl" />

                            <button type="submit" class="consent-btn consent-btn-secondary" name="deny" value="true">
                                <i class="bi bi-x-circle" aria-hidden="true"></i>
                                Deny access
                            </button>
                        </form>
                    </div>
                </main>

                <aside class="consent-pro-aside" aria-label="Application details">
                    <div class="consent-aside-card app-card">
                        <div class="app-card-logo" aria-hidden="true">
                            @if (branding.HasLogo)
                            {
                                <img src="@branding.LogoUrl" alt="@branding.TenantName" />
                            }
                            else
                            {
                                @appInitials
                            }
                        </div>
                        <div>
                            <span>Application</span>
                            <strong>@appName</strong>
                            <small>@clientId</small>
                        </div>
                    </div>

                    <div class="consent-aside-card">
                        <h3>Connection details</h3>
                        <dl class="consent-details-list">
                            <div>
                                <dt>Flow</dt>
                                <dd>@(string.IsNullOrWhiteSpace(responseType) ? "Authorization Code" : responseType)</dd>
                            </div>
                            <div>
                                <dt>PKCE protection</dt>
                                <dd class="is-positive">@(hasPkce ? $"Enabled{(string.IsNullOrWhiteSpace(codeChallengeMethod) ? string.Empty : $" ({codeChallengeMethod})")}" : "Not provided")</dd>
                            </div>
                            <div>
                                <dt>Response mode</dt>
                                <dd>@(string.IsNullOrWhiteSpace(responseMode) ? "Default" : responseMode)</dd>
                            </div>
                            <div>
                                <dt>Requested at</dt>
                                <dd>@requestedAtUtc</dd>
                            </div>
                        </dl>
                    </div>

                    <div class="consent-aside-card">
                        <h3>Redirect destination</h3>
                        <p class="consent-muted-text">After authorization, you will be sent back to:</p>
                        <div class="redirect-uri-box" title="@redirectUri">
                            <i class="bi bi-box-arrow-up-right" aria-hidden="true"></i>
                            <span>@(string.IsNullOrWhiteSpace(redirectUri) ? "No redirect URI provided" : redirectUri)</span>
                        </div>
                    </div>

                    <div class="consent-trust-card">
                        <i class="bi bi-lock-fill" aria-hidden="true"></i>
                        <span>Auth2Demo never shares your password with this application.</span>
                    </div>
                </aside>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/authorization-consent.css" asp-append-version="true" />
}
