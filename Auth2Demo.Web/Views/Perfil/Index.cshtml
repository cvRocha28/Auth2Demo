@model Auth2Demo.Web.Models.Perfil.PerfilIndexViewModel
@{
    ViewData["Title"] = T["MyAccount"];
    var user = Model.User;
    var initial = string.IsNullOrWhiteSpace(user.DisplayName) ? "U" : user.DisplayName[..1].ToUpperInvariant();
    var confirmedClass = user.EmailConfirmed ? "is-ok" : "is-warning";
    var mfaClass = Model.HasMfa ? "is-ok" : "is-warning";
    var externalClass = Model.HasExternalLogin ? "is-ok" : "is-warning";
    var trustedDevices = Model.Devices.Count(x => x.IsTrusted);
}

<div class="profile-page-shell">
    @if (TempData["Success"]?.ToString() is { } successKey)
    {
        <div class="alert success profile-alert"><i class="bi bi-check-circle" aria-hidden="true"></i> @T[successKey]</div>
    }
    @if (TempData["Error"]?.ToString() is { } errorKey)
    {
        <div class="alert profile-alert"><i class="bi bi-exclamation-triangle" aria-hidden="true"></i> @T[errorKey]@if (TempData["ErrorDetails"]?.ToString() is { } details) { <span> @details</span> }</div>
    }

    <section class="profile-pro-hero">
        <div class="profile-pro-cover"></div>
        <div class="profile-pro-main">
            <div class="profile-pro-avatar" aria-hidden="true">
                @if (!string.IsNullOrWhiteSpace(user.AvatarUrl))
                {
                    <img src="@user.AvatarUrl" alt='@T["ProfilePicture"].Value' referrerpolicy="no-referrer" />
                }
                else
                {
                    <span>@initial</span>
                }
            </div>

            <div class="profile-pro-identity">
                <span class="page-kicker">@T["Profile"]</span>
                <h1>@user.DisplayName</h1>
                <div class="profile-pro-email"><i class="bi bi-envelope" aria-hidden="true"></i> @user.Email</div>

                <div class="profile-pro-badges">
                    <span class="profile-status-pill @confirmedClass"><i class="bi @(user.EmailConfirmed ? "bi-patch-check" : "bi-clock")" aria-hidden="true"></i> @(user.EmailConfirmed ? T["EmailConfirmed"] : T["EmailPending"])</span>
                    <span class="profile-status-pill @mfaClass"><i class="bi bi-shield-lock" aria-hidden="true"></i> @(Model.HasMfa ? T["MfaEnabled"] : T["MfaDisabled"])</span>
                    <span class="profile-status-pill @(Model.HasLocalPassword ? "is-ok" : "is-warning")"><i class="bi bi-key" aria-hidden="true"></i> @(Model.HasLocalPassword ? T["LocalPasswordEnabled"] : T["LocalPasswordNotConfigured"])</span>
                    @if (Model.IsAdmin)
                    {
                        <span class="profile-status-pill is-admin"><i class="bi bi-stars" aria-hidden="true"></i> @T["AdminProfile"]</span>
                    }
                </div>
            </div>

            <div class="profile-pro-actions">
                <a class="btn" asp-controller="Account" asp-action="ManageMfa"><i class="bi bi-shield-lock" aria-hidden="true"></i> @T["OpenMfaSettings"]</a>
                @if (Model.IsAdmin)
                {
                    <a class="btn btn-outline" asp-area="Admin" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2" aria-hidden="true"></i> @T["OpenAdminPanel"]</a>
                }
            </div>
        </div>
    </section>

    <div class="profile-pro-metrics">
        <article class="profile-metric-card">
            <span><i class="bi bi-clock-history" aria-hidden="true"></i> @T["LastLogin"]</span>
            <strong>@(user.LastLoginAt?.ToLocalTime().ToString("HH:mm") ?? "-")</strong>
            <small>@(user.LastLoginAt?.ToLocalTime().ToString("dd/MM/yyyy") ?? T["NoRecord"].Value)</small>
        </article>
        <article class="profile-metric-card">
            <span><i class="bi bi-shield-check" aria-hidden="true"></i> @T["Mfa"]</span>
            <strong>@(Model.HasMfa ? T["Active"] : T["Pending"])</strong>
            <small>@T["MfaProfileHint"]</small>
        </article>
        <article class="profile-metric-card">
            <span><i class="bi bi-laptop" aria-hidden="true"></i> @T["Devices"]</span>
            <strong>@Model.Devices.Count</strong>
            <small>@T["TrustedDevicesFormat", trustedDevices]</small>
        </article>
        <article class="profile-metric-card">
            <span><i class="bi bi-key" aria-hidden="true"></i> @T["Passkeys"]</span>
            <strong>@Model.Passkeys.Count</strong>
            <small>@T["MfaPrepared"]</small>
        </article>
    </div>

    <div class="profile-pro-layout">
        <aside class="profile-pro-sidebar">
            <a href="#profile-general"><i class="bi bi-person" aria-hidden="true"></i> @T["EditProfile"]</a>
            <a href="#profile-security"><i class="bi bi-shield-lock" aria-hidden="true"></i> @T["SecurityCenter"]</a>
            <a href="#profile-password"><i class="bi bi-key" aria-hidden="true"></i> @(Model.HasLocalPassword ? T["ChangePassword"] : T["CreateLocalPassword"])</a>
            <a href="#profile-access"><i class="bi bi-box-arrow-in-right" aria-hidden="true"></i> @T["ExternalLogins"]</a>
            <a href="#profile-sessions"><i class="bi bi-activity" aria-hidden="true"></i> @T["RecentSessions"]</a>
            @if (Model.IsAdmin)
            {
                <a href="#profile-admin"><i class="bi bi-grid" aria-hidden="true"></i> @T["AdminShortcuts"]</a>
            }
        </aside>

        <main class="profile-pro-content">
            <section id="profile-general" class="profile-pro-card">
                <div class="profile-card-header">
                    <div>
                        <span class="page-kicker">@T["General"]</span>
                        <h2>@T["EditProfile"]</h2>
                        <p>@T["EditProfileText"]</p>
                    </div>
                </div>

                <div class="profile-two-columns">
                    <form asp-controller="Perfil" asp-action="AlterarDisplayName" method="post" class="profile-form-panel">
                        @Html.AntiForgeryToken()
                        <label for="displayName">@T["DisplayName"]</label>
                        <div class="profile-inline-field">
                            <input id="displayName" name="displayName" maxlength="100" required value="@user.DisplayName" />
                            <button class="btn" type="submit"><i class="bi bi-check2" aria-hidden="true"></i> @T["SaveDisplayName"]</button>
                        </div>
                        <span class="hint">@T["DisplayNameHint"]</span>
                    </form>

                    <form asp-controller="Perfil" asp-action="AlterarIdioma" method="post" class="profile-form-panel">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                        <label for="locale">@T["LanguagePreference"]</label>
                        <div class="profile-inline-field">
                            <select id="locale" name="locale">
                                <option value="pt-BR" selected="@(Model.CurrentLocale.Equals("pt-BR", StringComparison.OrdinalIgnoreCase))">@T["Portuguese"]</option>
                                <option value="en-US" selected="@(Model.CurrentLocale.Equals("en-US", StringComparison.OrdinalIgnoreCase))">@T["English"]</option>
                            </select>
                            <button class="btn btn-outline" type="submit"><i class="bi bi-translate" aria-hidden="true"></i> @T["Save"]</button>
                        </div>
                    </form>
                </div>

                <dl class="profile-pro-details">
                    <dt>@T["Email"]</dt><dd>@user.Email</dd>
                    <dt>@T["Username"]</dt><dd>@user.UserName</dd>
                    <dt>@T["Department"]</dt><dd>@(user.Department ?? T["NotInformed"].Value)</dd>
                    <dt>@T["JobTitle"]</dt><dd>@(user.JobTitle ?? T["NotInformed"].Value)</dd>
                    <dt>@T["TimeZone"]</dt><dd>@(user.TimeZone ?? T["NotInformed"].Value)</dd>
                    <dt>@T["CreatedAt"]</dt><dd>@user.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
                </dl>
            </section>

            <section id="profile-security" class="profile-pro-card">
                <div class="profile-card-header">
                    <div>
                        <span class="page-kicker">@T["SecurityCenter"]</span>
                        <h2>@T["SecurityCenter"]</h2>
                        <p>@T["ManageAccountText"]</p>
                    </div>
                    <a class="btn btn-outline" asp-controller="Account" asp-action="ManageMfa"><i class="bi bi-gear" aria-hidden="true"></i> @T["ConfigureMfa"]</a>
                </div>

                <div class="profile-security-grid">
                    <div class="profile-security-item @confirmedClass">
                        <i class="bi bi-envelope-check" aria-hidden="true"></i>
                        <div><strong>@T["Email"]</strong><span>@(user.EmailConfirmed ? T["EmailConfirmed"] : T["EmailPending"])</span></div>
                    </div>
                    <div class="profile-security-item @mfaClass">
                        <i class="bi bi-shield-lock" aria-hidden="true"></i>
                        <div><strong>@T["Mfa"]</strong><span>@(Model.HasMfa ? T["MfaEnabled"] : T["MfaDisabled"])</span></div>
                    </div>
                    <div class="profile-security-item @externalClass">
                        <i class="bi bi-globe2" aria-hidden="true"></i>
                        <div><strong>@T["ExternalLogins"]</strong><span>@(Model.HasExternalLogin ? T["ExternalLoginLinked"] : T["NoExternalLogin"])</span></div>
                    </div>
                    <div class="profile-security-item @(Model.HasLocalPassword ? "is-ok" : "is-warning")">
                        <i class="bi bi-key" aria-hidden="true"></i>
                        <div><strong>@T["LocalPassword"]</strong><span>@(Model.HasLocalPassword ? T["LocalPasswordEnabled"] : T["LocalPasswordNotConfigured"])</span></div>
                    </div>
                </div>
            </section>

            <section id="profile-password" class="profile-pro-card">
                <div class="profile-card-header">
                    <div>
                        <span class="page-kicker">@T["AccountAccess"]</span>
                        <h2>@(Model.HasLocalPassword ? T["ChangePassword"] : T["CreateLocalPassword"])</h2>
                        <p>@(Model.HasLocalPassword ? T["ChangePasswordText"] : T["CreateLocalPasswordText"])</p>
                    </div>
                </div>

                <form asp-controller="Perfil" asp-action="AlterarSenha" method="post" class="profile-password-panel" autocomplete="off">
                    @Html.AntiForgeryToken()
                    <div class="profile-password-grid">
                        @if (Model.HasLocalPassword)
                        {
                            <div class="profile-field-block">
                                <label for="currentPassword">@T["CurrentPassword"]</label>
                                <input id="currentPassword" name="currentPassword" type="password" autocomplete="current-password" required />
                            </div>
                        }
                        <div class="profile-field-block">
                            <label for="newPassword">@T["NewPassword"]</label>
                            <input id="newPassword" name="newPassword" type="password" autocomplete="new-password" minlength="10" required />
                            <span class="hint">@T["PasswordPolicyHint"]</span>
                        </div>
                        <div class="profile-field-block">
                            <label for="confirmPassword">@T["ConfirmPassword"]</label>
                            <input id="confirmPassword" name="confirmPassword" type="password" autocomplete="new-password" minlength="10" required />
                        </div>
                    </div>
                    <div class="profile-password-actions">
                        <button class="btn" type="submit"><i class="bi bi-key" aria-hidden="true"></i> @(Model.HasLocalPassword ? T["ChangePassword"] : T["CreateLocalPassword"])</button>
                        <span class="hint">@T["LocalPasswordProfessionalHint"]</span>
                    </div>
                </form>
            </section>

            @if (Model.IsAdmin)
            {
                <section id="profile-admin" class="profile-pro-card">
                    <div class="profile-card-header">
                        <div>
                            <span class="page-kicker">@T["AdminShortcuts"]</span>
                            <h2>@T["AdminShortcuts"]</h2>
                            <p>@T["AdminShortcutsText"]</p>
                        </div>
                    </div>

                    <div class="profile-shortcuts-grid">
                        <a class="profile-shortcut-card" asp-area="Admin" asp-controller="Users" asp-action="Index"><i class="bi bi-people" aria-hidden="true"></i><strong>@T["Users"]</strong><span>@T["ManageUsersText"]</span></a>
                        <a class="profile-shortcut-card" asp-area="Admin" asp-controller="Clients" asp-action="Index"><i class="bi bi-window-sidebar" aria-hidden="true"></i><strong>@T["Clients"]</strong><span>@T["ManageClientsText"]</span></a>
                        <a class="profile-shortcut-card" asp-area="Admin" asp-controller="AuditLogs" asp-action="Index"><i class="bi bi-clipboard-data" aria-hidden="true"></i><strong>@T["AuditLogs"]</strong><span>@T["AuditLogsText"]</span></a>
                    </div>
                </section>
            }

            <div id="profile-access" class="profile-pro-grid-two">
                <section class="profile-pro-card">
                    <div class="profile-card-header compact"><div><span class="page-kicker">@T["ExternalLogins"]</span><h2>@T["ExternalLogins"]</h2></div></div>
                    <div class="profile-list">
                        @if (Model.ExternalLogins.Any())
                        {
                            foreach (var login in Model.ExternalLogins)
                            {
                                <div class="profile-list-row"><span><i class="bi bi-link-45deg" aria-hidden="true"></i> @login.LoginProvider</span><strong>@T["Linked"]</strong></div>
                            }
                        }
                        else
                        {
                            <p class="muted">@T["NoExternalLogin"]</p>
                        }
                    </div>
                </section>

                <section class="profile-pro-card">
                    <div class="profile-card-header compact"><div><span class="page-kicker">@T["MfaAndPasskeys"]</span><h2>@T["MfaAndPasskeys"]</h2></div></div>
                    <div class="profile-list">
                        <div class="profile-list-row"><span>@T["MfaMethods"]</span><strong>@Model.MfaMethods.Count</strong></div>
                        <div class="profile-list-row"><span>@T["Passkeys"]</span><strong>@Model.Passkeys.Count</strong></div>
                    </div>
                </section>
            </div>

            <div id="profile-sessions" class="profile-pro-grid-two">
                <section class="profile-pro-card">
                    <div class="profile-card-header compact"><div><span class="page-kicker">@T["RecentSessions"]</span><h2>@T["RecentSessions"]</h2></div></div>
                    <div class="profile-list">
                        @if (!Model.Sessions.Any())
                        {
                            <p class="muted">@T["NoRecentSessions"]</p>
                        }
                        @foreach (var s in Model.Sessions)
                        {
                            <div class="profile-list-row">
                                <span><strong>@(s.DeviceName ?? T["NotInformed"].Value)</strong><small>@s.IpAddress</small></span>
                                <strong>@s.LastSeenAt.ToLocalTime().ToString("dd/MM HH:mm")</strong>
                            </div>
                        }
                    </div>
                </section>

                <section class="profile-pro-card">
                    <div class="profile-card-header compact"><div><span class="page-kicker">@T["Devices"]</span><h2>@T["Devices"]</h2></div></div>
                    <div class="profile-list">
                        @if (!Model.Devices.Any())
                        {
                            <p class="muted">@T["NoDevices"]</p>
                        }
                        @foreach (var d in Model.Devices)
                        {
                            <div class="profile-list-row">
                                <span><strong>@d.Name</strong><small>@d.Browser @d.OperatingSystem</small></span>
                                <strong>@(d.IsTrusted ? T["Trusted"] : T["New"])</strong>
                            </div>
                        }
                    </div>
                </section>
            </div>

            <section class="profile-pro-card">
                <div class="profile-card-header compact"><div><span class="page-kicker">@T["SecurityHistory"]</span><h2>@T["SecurityHistory"]</h2></div></div>
                <div class="profile-list">
                    @if (!Model.AuditLogs.Any())
                    {
                        <p class="muted">@T["NoSecurityHistory"]</p>
                    }
                    @foreach (var a in Model.AuditLogs)
                    {
                        <div class="profile-list-row">
                            <span><strong>@a.EventType</strong><small>@a.Description</small></span>
                            <strong>@a.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm")</strong>
                        </div>
                    }
                </div>
            </section>
        </main>
    </div>
</div>
