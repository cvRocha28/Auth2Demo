@model IReadOnlyList<ApplicationRole>
@{
    ViewData["Title"] = T["Roles"].Value;
}

@section AdminHeader {
    <span class="admin-page-kicker">@T["Permissions"]</span>
    <h1>@T["Roles"]</h1>
    <p>@T["TextCrieRolesPersonalizadasEAtribuaPermissoesAosUsuarios"]</p>
}



@if (TempData["Success"] is string success)
{
    <div class="alert alert-success">@success</div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert">@error</div>
}

<form method="post" asp-action="Create" class="card form-inline role-create-card">
    <div>
        <label for="name">@T["RoleName"]</label>
        <input id="name" name="name" placeholder='@T["TextExSupportManager"].Value' />
    </div>
    <div class="grow">
        <label for="description">@T["Description"]</label>
        <input id="description" name="description" placeholder='@T["ExpliqueOObjetivoDessaRole"].Value' />
    </div>
    <button class="btn" type="submit"><i class="bi bi-plus-circle"></i> @T["AdminCreateRole"]</button>
</form>

<div class="table-wrap">
    <table>
        <thead><tr><th>@T["Role"]</th><th>@T["Description"]</th><th>@T["Type"]</th><th class="actions-col">@T["Actions"]</th></tr></thead>
        <tbody>
        @foreach (var r in Model)
        {
            <tr>
                <td><strong>@r.Name</strong></td>
                <td>@(string.IsNullOrWhiteSpace(r.Description) ? "-" : r.Description)</td>
                <td><span class="badge @(r.IsSystemRole ? "badge-success" : string.Empty)">@(r.IsSystemRole ? T["AdminSystem"] : T["AdminCustom"])</span></td>
                <td>
                    @if (!r.IsSystemRole)
                    {
                        <form method="post" asp-action="Delete" asp-route-id="@r.Id" class="inline" data-confirm="@T["TextExcluirEstaRoleElaNaoPodeEstarAtribuida"].Value">
                            <button class="btn btn-outline btn-sm" type="submit">@T["Delete"]</button>
                        </form>
                    }
                    else
                    {
                        <span class="badge badge-success"><i class="bi bi-shield-lock"></i> @T["AdminProtected"]</span>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
