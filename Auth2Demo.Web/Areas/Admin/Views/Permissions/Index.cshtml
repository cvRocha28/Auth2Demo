@model Auth2Demo.Application.Services.Admin.AdminPermissionIndexData
@{
    ViewData["Title"] = T["Permissions"].Value;
}
<div class="page-heading">
    <div><span class="page-kicker">@T["Authorization"]</span><h1>@T["Permissions"]</h1><p>@T["ControleGranularNoEstilo"] <code>@T["TextUsersRead"]</code>, <code>@T["TextProvidersWrite"]</code> @T["Texte1671797"] <code>@T["TextClientsManage"]</code>.</p></div>
</div>
<div class="card"><form method="post" asp-action="Create" class="form-inline"><div><label>@T["Name"]</label><input name="name" placeholder='@T["TextUsersRead"].Value' /></div><div><label>@T["Display"]</label><input name="displayName" placeholder='@T["TextLerUsuarios"].Value' /></div><div><label>@T["Categoria"]</label><input name="category" placeholder='@T["Users"].Value' /></div><div class="grow"><label>@T["Description"]</label><input name="description" /></div><button class="btn">@T["Create"]</button></form></div>
<div class="table-wrap">
    <table>
        <thead>
            <tr>
                <th>@T["Permission"]</th>
                <th>@T["Categoria"]</th>@foreach(var r in Model.Roles){
                <th>@r.Name</th>
            }
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model.Permissions)
        {
            <tr>
                <td><strong>@p.Name</strong><br /><small class="muted">@p.DisplayName</small></td>
                <td>@p.Category</td>@foreach(var r in Model.Roles){var has=Model.RolePermissions.Any(x=>x.RoleId==r.Id && x.PermissionId==p.Id);
                <td><form method="post" asp-action="Toggle"><input type="hidden" name="roleId" value="@r.Id" /><input type="hidden" name="permissionId" value="@p.Id" /><button class="btn btn-sm @(has ? "" : "btn-outline")">@(has ? "Permitido" : "Adicionar")</button></form></td>
            }
        </tr>
    }
</tbody>
</table>
</div>
