@model IReadOnlyList<Auth2Demo.Domain.Security.UserSession>
@{ ViewData["Title"] = T["TextSessoes"].Value; }
@section AdminHeader {
    <span class="admin-page-kicker">@T["Security"]</span>
    <h1>@T["ActiveSessions"]</h1>
    <p>@T["TextVisualizeERevogueSessoesDeUsuarios"]</p>
}


<div class="table-wrap"><table><thead><tr><th>@T["User"]</th><th>@T["Dispositivo"]</th><th>@T["Ip"]</th><th>@T["LastActivity"]</th><th>@T["Status"]</th><th>@T["Actions"]</th></tr></thead><tbody>@foreach (var s in Model){<tr><td>@s.UserEmail</td><td>@s.DeviceName<br/><small class="muted">@s.UserAgent</small></td><td>@s.IpAddress</td><td>@s.LastSeenAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td><td><span class="badge @(s.IsRevoked ? "badge-danger" : "badge-success")">@(s.IsRevoked ? "Revogada" : "Ativa")</span></td><td>@if(!s.IsRevoked){<form method="post" asp-action="Revoke"><input type="hidden" name="id" value="@s.Id"/><button class="btn btn-sm btn-danger">@T["Revogar"]</button></form>}</td></tr>}</tbody></table></div>
