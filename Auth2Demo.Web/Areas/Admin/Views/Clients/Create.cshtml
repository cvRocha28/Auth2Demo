@model ClientFormViewModel
@{
    ViewData["Title"] = T["NewClient"].Value;
}

@section AdminHeader {
    <span class="admin-page-kicker">@T["OpenIddict"]</span>
    <h1>@T["NewClient"]</h1>
    <p>@T["ClientCreatePageDescription"]</p>
}

@section AdminActions {
    <a class="btn ghost" asp-action="Index"><i class="bi bi-arrow-left"></i> @T["Back"]</a>
}

<partial name="_ClientForm" model="Model" />
