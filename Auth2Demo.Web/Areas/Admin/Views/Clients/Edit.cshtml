@model ClientFormViewModel
@{
    ViewData["Title"] = string.Format("{0} {1}", T["EditClient"].Value, Model.ClientId);
}

<div class="page-heading">
    <div>
        <span class="page-kicker">@T["OpenIddict"]</span>
        <h1>@T["EditClient"]</h1>
        <p>@T["TextAltereGrantsEndpointsRedirectsScopesEConsentimentoDo"]</p>
    </div>
    <a class="btn ghost" asp-action="Details" asp-route-clientId="@Model.OriginalClientId">@T["Back"]</a>
</div>

<partial name="_ClientForm" model="Model" />
