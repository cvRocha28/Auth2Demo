@model IReadOnlyList<ClientIndexViewModel>
@{
    ViewData["Title"] = T["Clients"].Value;
}

<div class="page-heading">
    <div>
        <span class="page-kicker">@T["OpenIddict"]</span>
        <h1>@T["Clients"]</h1>
        <p>@T["TextAplicacoesAutorizadasAUsarSeuIdentityProvider"]</p>
    </div>
    <a class="btn" asp-action="Create">@T["NewClient"]</a>
</div>

@if (TempData["Success"] is string success)
{
    <div class="alert success">@success</div>
}

<div class="table-wrap">
    <table>
        <thead>
            <tr>
                <th>@T["ClientId"]</th>
                <th>@T["Name"]</th>
                <th>@T["Type"]</th>
                <th>@T["Consent"]</th>
                <th>@T["Grants"]</th>
                <th class="actions-col">@T["Actions"]</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Count == 0)
        {
            <tr><td colspan="6" class="empty">@T["NoClientsRegistered"]</td></tr>
        }
        else
        {
            foreach (var client in Model)
            {
                <tr>
                    <td><code>@client.ClientId</code></td>
                    <td>@client.DisplayName</td>
                    <td><span class="badge">@client.ClientType</span></td>
                    <td><span class="badge">@client.ConsentType</span></td>
                    <td>
                        @if (client.GrantTypes.Count == 0)
                        {
                            <span class="muted">@T["None"]</span>
                        }
                        else
                        {
                            foreach (var grant in client.GrantTypes)
                            {
                                <span class="badge">@grant</span>
                            }
                        }
                    </td>
                    <td>
                        <a class="btn btn-outline btn-sm" asp-action="Details" asp-route-clientId="@client.ClientId">@T["Details"]</a>
                        <a class="btn btn-outline btn-sm" asp-action="Edit" asp-route-clientId="@client.ClientId">@T["Edit"]</a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>
