@model IReadOnlyList<ClientIndexViewModel>
@{
    ViewData["Title"] = T["Clients"].Value;
    var totalClients = Model.Count;
    var confidentialClients = Model.Count(client => string.Equals(client.ClientType, OpenIddictConstants.ClientTypes.Confidential, StringComparison.Ordinal));
    var customBrandingClients = Model.Count(client => client.BrandingEnabled);
    var codeFlowClients = Model.Count(client => client.GrantTypes.Any(grant => string.Equals(grant, "authorization_code", StringComparison.OrdinalIgnoreCase)));
}

@section AdminHeader {
    <span class="admin-page-kicker">@T["OpenIddict"]</span>
    <h1>@T["Clients"]</h1>
    <p>@T["TextAplicacoesAutorizadasAUsarSeuIdentityProvider"]</p>
}

@section AdminActions {
    <a class="btn" asp-action="Create"><i class="bi bi-plus-lg"></i> @T["NewClient"]</a>
}

@if (TempData["Success"] is string success)
{
    <div class="alert success">@success</div>
}

<section class="clients-command-center">
    <div class="client-stat-card">
        <span>Total clients</span>
        <strong>@totalClients</strong>
        <small>Active OpenIddict applications</small>
    </div>
    <div class="client-stat-card">
        <span>Confidential</span>
        <strong>@confidentialClients</strong>
        <small>Server-side clients</small>
    </div>
    <div class="client-stat-card accent">
        <span>Custom branding</span>
        <strong>@customBrandingClients</strong>
        <small>White label enabled</small>
    </div>
    <div class="client-stat-card">
        <span>Code flow</span>
        <strong>@codeFlowClients</strong>
        <small>Authorization code enabled</small>
    </div>
</section>

<section class="card clients-filter-card">
    <div class="clients-filter-header">
        <div>
            <span class="admin-page-kicker">Client directory</span>
            <h2>Manage applications</h2>
            <p>Search, filter, review configuration and jump directly into branding.</p>
        </div>
        <a class="btn btn-outline" asp-action="Create"><i class="bi bi-plus-circle"></i> New client</a>
    </div>

    <div class="clients-filter-grid">
        <label class="client-filter-field search-field">
            <span>Search</span>
            <div class="client-search-box">
                <i class="bi bi-search"></i>
                <input id="clientSearch" type="search" placeholder="Client ID, display name or grant..." autocomplete="off" />
            </div>
        </label>

        <label class="client-filter-field">
            <span>Type</span>
            <select id="clientTypeFilter">
                <option value="">All types</option>
                <option value="confidential">Confidential</option>
                <option value="public">Public</option>
            </select>
        </label>

        <label class="client-filter-field">
            <span>Grant</span>
            <select id="clientGrantFilter">
                <option value="">All grants</option>
                <option value="authorization_code">Authorization code</option>
                <option value="refresh_token">Refresh token</option>
                <option value="client_credentials">Client credentials</option>
            </select>
        </label>

        <label class="client-filter-field">
            <span>Branding</span>
            <select id="clientBrandingFilter">
                <option value="">All</option>
                <option value="enabled">Custom enabled</option>
                <option value="global">Using global</option>
            </select>
        </label>
    </div>
</section>

<section class="clients-table-card">
    <div class="clients-table-toolbar">
        <div>
            <strong>Registered clients</strong>
            <span id="clientResultCount">@totalClients clients</span>
        </div>
        <button type="button" class="btn btn-outline btn-sm" id="clearClientFilters"><i class="bi bi-x-circle"></i> Clear filters</button>
    </div>

    <div class="professional-client-table-wrap">
        <table class="professional-client-table" id="clientsTable">
            <thead>
                <tr>
                    <th>Application</th>
                    <th>Security</th>
                    <th>Grants</th>
                    <th>Branding</th>
                    <th class="actions-col">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr><td colspan="5" class="empty">@T["NoClientsRegistered"]</td></tr>
            }
            else
            {
                foreach (var client in Model)
                {
                    var searchText = $"{client.ClientId} {client.DisplayName} {client.ClientType} {client.ConsentType} {string.Join(' ', client.GrantTypes)}".ToLowerInvariant();
                    var grants = string.Join(',', client.GrantTypes).ToLowerInvariant();
                    <tr class="client-row"
                        data-search="@searchText"
                        data-type="@client.ClientType.ToLowerInvariant()"
                        data-grants="@grants"
                        data-branding="@(client.BrandingEnabled ? "enabled" : "global")">
                        <td>
                            <div class="client-identity-cell">
                                <div class="client-avatar">@((client.DisplayName.FirstOrDefault() == default ? client.ClientId.FirstOrDefault() : client.DisplayName.FirstOrDefault()).ToString().ToUpperInvariant())</div>
                                <div>
                                    <strong>@client.DisplayName</strong>
                                    <code>@client.ClientId</code>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="client-security-stack">
                                <span class="client-pill strong"><i class="bi bi-shield-lock"></i> @client.ClientType</span>
                                <span class="client-pill"><i class="bi bi-check2-circle"></i> @client.ConsentType consent</span>
                            </div>
                        </td>
                        <td>
                            <div class="client-grants-list">
                                @if (client.GrantTypes.Count == 0)
                                {
                                    <span class="muted">@T["None"]</span>
                                }
                                else
                                {
                                    foreach (var grant in client.GrantTypes)
                                    {
                                        <span class="client-pill grant-pill">@grant</span>
                                    }
                                }
                            </div>
                        </td>
                        <td>
                            @if (client.BrandingEnabled)
                            {
                                <span class="client-branding-status enabled"><i class="bi bi-palette-fill"></i> Custom enabled</span>
                            }
                            else
                            {
                                <span class="client-branding-status"><i class="bi bi-globe2"></i> Global default</span>
                            }
                        </td>
                        <td>
                            <div class="client-actions">
                                <a class="client-action-button primary" asp-action="Branding" asp-route-clientId="@client.ClientId" title="Edit client branding"><i class="bi bi-palette"></i><span>Branding</span></a>
                                <a class="client-action-button" asp-action="Details" asp-route-clientId="@client.ClientId" title="View details"><i class="bi bi-eye"></i><span>Details</span></a>
                                <a class="client-action-button" asp-action="Edit" asp-route-clientId="@client.ClientId" title="Edit client"><i class="bi bi-pencil-square"></i><span>Edit</span></a>
                            </div>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>

    <div class="clients-empty-state" id="clientsEmptyState" hidden>
        <div><i class="bi bi-search"></i></div>
        <strong>No clients found</strong>
        <span>Try changing the search text or clearing the filters.</span>
    </div>
</section>

<style>
    .clients-command-center{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:16px;margin-bottom:18px}
    .client-stat-card{padding:18px;border:1px solid rgba(148,163,184,.22);border-radius:24px;background:rgba(255,255,255,.92);box-shadow:0 12px 30px rgba(15,23,42,.06)}
    .client-stat-card span{display:block;color:#64748b;font-size:.78rem;font-weight:900;text-transform:uppercase;letter-spacing:.08em}
    .client-stat-card strong{display:block;margin:6px 0;color:#0f172a;font-size:2rem;line-height:1;font-weight:950;letter-spacing:-.05em}
    .client-stat-card small{color:#64748b;font-weight:700}
    .client-stat-card.accent{background:linear-gradient(135deg,rgba(37,99,235,.08),rgba(15,23,42,.03));border-color:rgba(37,99,235,.20)}
    .clients-filter-card{padding:22px;margin-bottom:18px;border-radius:28px}.clients-filter-header{display:flex;justify-content:space-between;gap:16px;align-items:flex-start;margin-bottom:18px}.clients-filter-header h2{margin:4px 0 4px;color:#0f172a;font-size:1.45rem;font-weight:950;letter-spacing:-.04em}.clients-filter-header p{margin:0;color:#64748b}.clients-filter-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:14px}.client-filter-field span{display:block;margin-bottom:7px;color:#334155;font-size:.84rem;font-weight:900}.client-filter-field input,.client-filter-field select{width:100%;height:46px;border:1px solid #dbe4f0;border-radius:16px;background:#fff;color:#0f172a;padding:0 14px;outline:none;font-weight:700}.client-filter-field input:focus,.client-filter-field select:focus{border-color:rgba(37,99,235,.55);box-shadow:0 0 0 4px rgba(37,99,235,.10)}.client-search-box{position:relative}.client-search-box i{position:absolute;top:50%;left:14px;transform:translateY(-50%);color:#94a3b8}.client-search-box input{padding-left:42px}
    .clients-table-card{border:1px solid rgba(148,163,184,.22);border-radius:28px;background:#fff;box-shadow:0 18px 50px rgba(15,23,42,.08);overflow:hidden}.clients-table-toolbar{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:18px 20px;border-bottom:1px solid rgba(148,163,184,.18);background:linear-gradient(180deg,#fff,#f8fafc)}.clients-table-toolbar strong{display:block;color:#0f172a;font-size:1.05rem;font-weight:950}.clients-table-toolbar span{display:block;margin-top:2px;color:#64748b;font-size:.84rem;font-weight:700}.professional-client-table-wrap{overflow-x:auto}.professional-client-table{width:100%;border-collapse:separate;border-spacing:0}.professional-client-table th{padding:14px 20px;color:#475569;background:#f8fafc;border-bottom:1px solid rgba(148,163,184,.18);font-size:.76rem;font-weight:950;text-transform:uppercase;letter-spacing:.08em;text-align:left}.professional-client-table td{padding:18px 20px;border-bottom:1px solid rgba(148,163,184,.14);vertical-align:middle}.professional-client-table tbody tr{transition:.16s ease}.professional-client-table tbody tr:hover{background:linear-gradient(90deg,rgba(37,99,235,.045),rgba(15,23,42,.018))}.professional-client-table tbody tr:last-child td{border-bottom:0}.client-identity-cell{display:flex;align-items:center;gap:14px;min-width:280px}.client-avatar{width:46px;height:46px;border-radius:16px;display:grid;place-items:center;color:#fff;background:linear-gradient(135deg,#2563eb,#0f172a);font-weight:950;box-shadow:0 14px 30px rgba(37,99,235,.18)}.client-identity-cell strong{display:block;color:#0f172a;font-size:1rem;font-weight:950}.client-identity-cell code{display:inline-flex;margin-top:6px;padding:5px 9px;border:1px solid rgba(37,99,235,.18);border-radius:999px;color:#2563eb;background:#eff6ff;font-size:.84rem;font-weight:850}.client-security-stack,.client-grants-list{display:flex;gap:8px;flex-wrap:wrap}.client-pill{display:inline-flex;align-items:center;gap:6px;padding:8px 11px;border-radius:999px;color:#334155;background:#eef2f7;font-size:.8rem;font-weight:900}.client-pill.strong{color:#1e3a8a;background:#dbeafe}.grant-pill{font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace}.client-branding-status{display:inline-flex;align-items:center;gap:7px;padding:9px 12px;border-radius:999px;color:#64748b;background:#f1f5f9;font-size:.82rem;font-weight:950;white-space:nowrap}.client-branding-status.enabled{color:#1d4ed8;background:rgba(37,99,235,.10)}.client-actions{display:flex;justify-content:flex-end;gap:8px;flex-wrap:wrap;min-width:260px}.client-action-button{display:inline-flex;align-items:center;gap:7px;min-height:38px;padding:8px 12px;border:1px solid #dbeafe;border-radius:14px;color:#2563eb;background:#fff;font-weight:900;text-decoration:none;transition:.16s ease}.client-action-button:hover{transform:translateY(-1px);color:#1d4ed8;background:#eff6ff;box-shadow:0 12px 26px rgba(37,99,235,.12)}.client-action-button.primary{color:#fff;border-color:transparent;background:#2563eb;box-shadow:0 14px 30px rgba(37,99,235,.20)}.client-action-button.primary:hover{color:#fff;background:#1d4ed8}.clients-empty-state{display:grid;place-items:center;text-align:center;gap:7px;padding:42px;color:#64748b}.clients-empty-state div{width:62px;height:62px;border-radius:22px;display:grid;place-items:center;color:#fff;background:linear-gradient(135deg,#2563eb,#0f172a);font-size:1.45rem}.clients-empty-state strong{color:#0f172a;font-size:1.1rem;font-weight:950}.clients-empty-state span{font-weight:700}
    @@media (max-width:1100px){.clients-command-center{grid-template-columns:repeat(2,minmax(0,1fr))}.clients-filter-grid{grid-template-columns:1fr 1fr}.search-field{grid-column:1/-1}}@@media (max-width:720px){.clients-command-center,.clients-filter-grid{grid-template-columns:1fr}.clients-filter-header,.clients-table-toolbar{flex-direction:column;align-items:stretch}.client-actions{justify-content:flex-start;min-width:0}.client-action-button span{display:none}.professional-client-table th,.professional-client-table td{padding:14px}}
</style>

<script>
    (() => {
        const table = document.getElementById('clientsTable');
        if (!table) return;

        const rows = Array.from(table.querySelectorAll('tbody tr.client-row'));
        const search = document.getElementById('clientSearch');
        const type = document.getElementById('clientTypeFilter');
        const grant = document.getElementById('clientGrantFilter');
        const branding = document.getElementById('clientBrandingFilter');
        const count = document.getElementById('clientResultCount');
        const empty = document.getElementById('clientsEmptyState');
        const clear = document.getElementById('clearClientFilters');

        const normalize = value => (value || '').trim().toLowerCase();

        function applyFilters() {
            const q = normalize(search.value);
            const selectedType = normalize(type.value);
            const selectedGrant = normalize(grant.value);
            const selectedBranding = normalize(branding.value);
            let visible = 0;

            rows.forEach(row => {
                const matchesSearch = !q || row.dataset.search.includes(q);
                const matchesType = !selectedType || row.dataset.type === selectedType;
                const matchesGrant = !selectedGrant || row.dataset.grants.includes(selectedGrant);
                const matchesBranding = !selectedBranding || row.dataset.branding === selectedBranding;
                const show = matchesSearch && matchesType && matchesGrant && matchesBranding;
                row.hidden = !show;
                if (show) visible++;
            });

            count.textContent = visible === 1 ? '1 client' : `${visible} clients`;
            empty.hidden = visible !== 0;
        }

        [search, type, grant, branding].forEach(input => input.addEventListener('input', applyFilters));
        clear.addEventListener('click', () => {
            search.value = '';
            type.value = '';
            grant.value = '';
            branding.value = '';
            applyFilters();
            search.focus();
        });
    })();
</script>
