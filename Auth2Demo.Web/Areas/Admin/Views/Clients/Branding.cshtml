@model ClientBrandingViewModel

@{
    ViewData["Title"] = "Client branding";
    var clientTitle = string.IsNullOrWhiteSpace(Model.DisplayName) ? Model.ClientId : Model.DisplayName;

    var colorFields = new[]
    {
        new { Name = nameof(Model.PrimaryColor), Label = "Primary", Description = "Main action, links and focus rings.", Value = Model.PrimaryColor },
        new { Name = nameof(Model.SecondaryColor), Label = "Secondary", Description = "Gradient end color and accent highlights.", Value = Model.SecondaryColor },
        new { Name = nameof(Model.BackgroundColor), Label = "Background", Description = "Authentication page background.", Value = Model.BackgroundColor },
        new { Name = nameof(Model.SurfaceColor), Label = "Surface", Description = "Cards, inputs and panels.", Value = Model.SurfaceColor },
        new { Name = nameof(Model.TextColor), Label = "Text", Description = "Headings and primary text.", Value = Model.TextColor },
        new { Name = nameof(Model.MutedTextColor), Label = "Muted text", Description = "Descriptions and secondary text.", Value = Model.MutedTextColor },
        new { Name = nameof(Model.BorderColor), Label = "Border", Description = "Card and input borders.", Value = Model.BorderColor },
        new { Name = nameof(Model.SuccessColor), Label = "Success", Description = "Trust badges and positive states.", Value = Model.SuccessColor },
        new { Name = nameof(Model.WarningColor), Label = "Warning", Description = "Warnings and attention states.", Value = Model.WarningColor },
        new { Name = nameof(Model.DangerColor), Label = "Danger", Description = "Errors and deny actions.", Value = Model.DangerColor }
    };
}
@section AdminHeader {
    <span class="admin-page-kicker">Client customization</span>
    <h1>Branding - @clientTitle</h1>
    <p>Configure the exact visual identity used by login, register and authorization screens for this client.</p>
    <div class="admin-page-meta">
        <span><strong>Client ID:</strong> <code>@Model.ClientId</code></span>
        <span><strong>Status:</strong> @(Model.IsEnabled ? "Enabled" : "Using global branding")</span>
    </div>
}

@section AdminActions {
    <a class="btn ghost" asp-action="Details" asp-route-clientId="@Model.ClientId"><i class="bi bi-arrow-left"></i> Back to client</a>
}

@if (TempData["Success"] is string success)
{
    <div class="alert success">@success</div>
}

<form method="post" class="branding-studio" id="clientBrandingForm" data-client-title="@clientTitle">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ClientId" />
    <input type="hidden" asp-for="DisplayName" />

    <section class="card branding-studio-panel">
        <div class="branding-studio-head">
            <div>
                <span class="page-kicker">Brand studio</span>
                <h2>Client visual identity</h2>
                <p class="muted">Use design tokens instead of isolated colors. The same configuration powers login, register and authorization screens.</p>
            </div>
            <label class="studio-switch">
                <input asp-for="IsEnabled" data-preview-token="IsEnabled" />
                <span></span>
                <strong>Enable custom branding</strong>
            </label>
        </div>

        <div class="preset-strip" aria-label="Brand presets">
            <button type="button" class="preset-chip" data-preset="auth2demo"><i class="bi bi-shield-lock"></i> Auth2Demo</button>
            <button type="button" class="preset-chip" data-preset="corporate"><i class="bi bi-bank"></i> Corporate Blue</button>
            <button type="button" class="preset-chip" data-preset="slate"><i class="bi bi-columns-gap"></i> Slate</button>
            <button type="button" class="preset-chip" data-preset="emerald"><i class="bi bi-check2-shield"></i> Emerald Trust</button>
            <button type="button" class="preset-chip" data-preset="indigo"><i class="bi bi-gem"></i> Indigo Pro</button>
            <button type="button" class="preset-chip" data-preset="dark"><i class="bi bi-moon-stars"></i> Dark Enterprise</button>
        </div>

        <div class="branding-tabs" role="tablist">
            <button type="button" class="branding-tab active" data-tab-target="general">General</button>
            <button type="button" class="branding-tab" data-tab-target="colors">Colors</button>
            <button type="button" class="branding-tab" data-tab-target="appearance">Appearance</button>
            <button type="button" class="branding-tab" data-tab-target="authentication">Authentication Methods</button>
            <button type="button" class="branding-tab" data-tab-target="advanced">Advanced</button>
        </div>

        <div class="branding-tab-panel active" data-tab-panel="general">
            <div class="grid two">
                <div class="form-row">
                    <label asp-for="TenantName">Display name</label>
                    <input asp-for="TenantName" placeholder="Auth2Demo, Internal Portal, Partner App" data-preview-token="TenantName" />
                    <small>Name shown in authentication experiences.</small>
                    <span asp-validation-for="TenantName"></span>
                </div>
                <div class="form-row">
                    <label asp-for="Theme">Theme</label>
                    <select asp-for="Theme" data-preview-token="Theme">
                        <option value="Light">Light</option>
                        <option value="Dark">Dark</option>
                    </select>
                    <small>Controls default contrast and background behavior.</small>
                </div>
                <div class="form-row">
                    <label asp-for="LogoUrl">Logo URL</label>
                    <input asp-for="LogoUrl" placeholder="https://cdn.example.com/logo.svg" data-preview-token="LogoUrl" />
                    <small>Use PNG/SVG with transparent background for best result.</small>
                    <span asp-validation-for="LogoUrl"></span>
                </div>
                <div class="form-row">
                    <label asp-for="FaviconUrl">Favicon URL</label>
                    <input asp-for="FaviconUrl" placeholder="https://cdn.example.com/favicon.ico" />
                    <small>Browser icon used when this branding is active.</small>
                    <span asp-validation-for="FaviconUrl"></span>
                </div>
            </div>
        </div>

        <div class="branding-tab-panel" data-tab-panel="colors">
            <div class="token-grid">
                @foreach (var color in colorFields)
                {
                    <div class="form-row token-color-field" data-color-field>
                        <label for="@color.Name">@color.Label</label>
                        <div class="token-color-control">
                            <input class="token-color-picker" type="color" value="@color.Value" data-color-picker aria-label="@color.Label picker" />
                            <input id="@color.Name" name="@color.Name" class="token-color-text" value="@color.Value" maxlength="7" data-color-text data-preview-token="@color.Name" />
                            <button class="token-copy-button" type="button" data-copy-color title="Copy color"><i class="bi bi-copy"></i></button>
                        </div>
                        <small>@color.Description</small>
                        <span class="field-validation-valid" data-valmsg-for="@color.Name" data-valmsg-replace="true"></span>
                    </div>
                }
            </div>
        </div>

        <div class="branding-tab-panel" data-tab-panel="appearance">
            <div class="grid two">
                <div class="form-row range-row">
                    <label asp-for="CardRadius">Card radius <strong><span data-range-value="CardRadius">@Model.CardRadius</span>px</strong></label>
                    <input asp-for="CardRadius" type="range" min="8" max="48" data-preview-token="CardRadius" />
                    <span asp-validation-for="CardRadius"></span>
                </div>
                <div class="form-row range-row">
                    <label asp-for="ButtonRadius">Button radius <strong><span data-range-value="ButtonRadius">@Model.ButtonRadius</span>px</strong></label>
                    <input asp-for="ButtonRadius" type="range" min="6" max="32" data-preview-token="ButtonRadius" />
                    <span asp-validation-for="ButtonRadius"></span>
                </div>
            </div>

            <div class="option-grid">
                <label class="option-card">
                    <input asp-for="UseGradientButtons" data-preview-token="UseGradientButtons" />
                    <span><i class="bi bi-palette2"></i></span>
                    <strong>Gradient buttons</strong>
                    <small>Use primary + secondary gradient for main actions.</small>
                </label>
                <label class="option-card">
                    <input asp-for="ShowCreateAccountLink" data-preview-token="ShowCreateAccountLink" />
                    <span><i class="bi bi-person-plus"></i></span>
                    <strong>Show create account</strong>
                    <small>Keep registration links visible while preserving ReturnUrl.</small>
                </label>
                <label class="option-card">
                    <input asp-for="ShowForgotPasswordLink" data-preview-token="ShowForgotPasswordLink" />
                    <span><i class="bi bi-key"></i></span>
                    <strong>Show forgot password</strong>
                    <small>Display password recovery link on login.</small>
                </label>
                <label class="option-card">
                    <input asp-for="ShowAuthorizationDeniedPage" />
                    <span><i class="bi bi-shield-exclamation"></i></span>
                    <strong>Show access denied screen</strong>
                    <small>When disabled, authorization errors return directly to the requesting application.</small>
                </label>
            </div>
        </div>


        <div class="branding-tab-panel" data-tab-panel="authentication">
            <div class="auth-methods-panel">
                <div class="auth-methods-header">
                    <div>
                        <h3>Authentication methods</h3>
                        <p class="muted">Choose which sign-in options this client can show. External providers come from enabled IdentityProviders.</p>
                    </div>
                    <span class="method-count"><strong data-method-count>0</strong> enabled</span>
                </div>

                <label class="auth-method-card local-method-card">
                    <input asp-for="EnableLocalLogin" data-preview-token="EnableLocalLogin" data-auth-method="local" />
                    <span class="auth-method-icon"><i class="bi bi-person-lock"></i></span>
                    <span class="auth-method-copy">
                        <strong>Username / Email + Password</strong>
                        <small>Show the local email and password form.</small>
                    </span>
                    <span class="auth-method-status">Built-in</span>
                </label>

                <div class="auth-method-section-title">
                    <strong>External providers</strong>
                    <small>Only enabled and configured providers can be used on the real login screen.</small>
                </div>

                @if (Model.ProviderOptions.Count == 0)
                {
                    <div class="empty-state small-empty-state">
                        <strong>No enabled identity providers found.</strong>
                        <span>Enable providers in Administration / Authentication / Identity Providers.</span>
                    </div>
                }
                else
                {
                    <div class="auth-method-grid">
                        @foreach (var provider in Model.ProviderOptions)
                        {
                            var isChecked = Model.EnabledProviderSchemes.Contains(provider.Scheme, StringComparer.OrdinalIgnoreCase);
                            <label class="auth-method-card provider-method-card @(provider.IsConfigured ? null : "is-not-configured")">
                                <input type="checkbox"
                                       name="EnabledProviderSchemes"
                                       value="@provider.Scheme"
                                       checked="@(isChecked ? "checked" : null)"
                                       disabled="@(provider.IsConfigured ? null : "disabled")"
                                       data-preview-token="Provider"
                                       data-auth-provider
                                       data-provider-name="@provider.DisplayName"
                                       data-provider-scheme="@provider.Scheme" />
                                <span class="auth-method-icon provider-icon">@provider.DisplayName.Substring(0, 1)</span>
                                <span class="auth-method-copy">
                                    <strong>@provider.DisplayName</strong>
                                    <small>@(provider.IsConfigured ? provider.Scheme : "Provider missing client id or secret")</small>
                                </span>
                                <span class="auth-method-status">@(provider.IsConfigured ? "Available" : "Not configured")</span>
                            </label>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="branding-tab-panel" data-tab-panel="advanced">
            <div class="form-row">
                <label asp-for="CustomCss">Custom CSS</label>
                <textarea asp-for="CustomCss" rows="12" class="code-editor" placeholder=".auth-card { border-radius: 28px; }" data-preview-token="CustomCss"></textarea>
                <small>Advanced override. Keep this small and prefer tokens above whenever possible.</small>
                <span asp-validation-for="CustomCss"></span>
            </div>
        </div>

        <div class="actions-row sticky-actions">
            <button class="btn" type="submit"><i class="bi bi-save"></i> Save client branding</button>
            <a class="btn ghost" asp-action="Details" asp-route-clientId="@Model.ClientId">Cancel</a>
        </div>
    </section>

    <aside class="branding-live-panel">
        <div class="card branding-preview-card pro-preview-card">
            <div class="preview-toolbar">
                <div>
                    <span class="page-kicker">Live preview</span>
                    <strong>Same authentication components</strong>
                </div>
                <div class="preview-device-switch">
                    <button type="button" class="active" data-device="desktop"><i class="bi bi-display"></i></button>
                    <button type="button" data-device="mobile"><i class="bi bi-phone"></i></button>
                </div>
            </div>

            <div class="studio-preview-stage" id="brandingPreviewStage">
                <div class="studio-preview-window" id="brandingPreviewWindow">
                    <div class="auth-card form-card auth-tenant-card preview-auth-card">
                        <div class="auth-header auth-tenant-header">
                            <div class="auth-badge" id="previewLogoBadge">
                                @if (!string.IsNullOrWhiteSpace(Model.LogoUrl))
                                {
                                    <img src="@Model.LogoUrl" alt="Logo preview" />
                                }
                                else
                                {
                                    <i class="bi bi-shield-lock" aria-hidden="true"></i>
                                }
                            </div>
                            <h1 id="previewTenantName">@(string.IsNullOrWhiteSpace(Model.TenantName) ? clientTitle : Model.TenantName)</h1>
                            <p>Sign in to continue securely.</p>
                        </div>
                        <div class="auth-form preview-auth-form">
                            <div id="previewLocalLogin">
                            <div class="form-row">
                                <label>Email</label>
                                <div class="input-wrap"><span class="input-icon"><i class="bi bi-envelope"></i></span><input class="with-icon" value="you@example.com" readonly /></div>
                            </div>
                            <div class="form-row">
                                <label>Password</label>
                                <div class="input-wrap"><span class="input-icon"><i class="bi bi-key"></i></span><input class="with-icon" value="••••••••••" readonly /></div>
                            </div>
                            <div class="login-options-row">
                                <label class="check"><input type="checkbox" /> <span>Remember access</span></label>
                                <a class="forgot-password-link" id="previewForgotLink">Forgot password?</a>
                            </div>
                            <button class="btn btn-block" type="button">Login</button>
                            </div>
                            <div id="previewProviderArea">
                                <div class="external-login-divider"><span>or continue with</span></div>
                                <div class="external-login-list" id="previewProviderList"></div>
                            </div>
                            <div class="alert is-hidden" id="previewNoMethods">No authentication method enabled.</div>
                            <p class="form-footer" id="previewCreateAccount">Don't have an account? <a>Create account</a></p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="preview-note">
                <i class="bi bi-info-circle"></i>
                Preview uses the same classes and tokens as the real login screen. Save to apply to this client.
            </div>
        </div>
    </aside>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/pages/clients-branding.js" asp-append-version="true" defer></script>
}
