@model IReadOnlyList<Auth2Demo.Application.Services.Admin.DirectoryUserRowData>
@{ ViewData["Title"] = "Directory users"; var selectedCompany = ViewBag.CompanyId as Guid?; }
@section AdminHeader {
    <span class="admin-page-kicker"><i class="bi bi-person-lines-fill"></i> DIRECTORY</span>
    <h1>Users</h1>
    <p>Search identities and understand their tenant and group footprint before changing access.</p>
}
@section AdminActions { <a class="btn btn-primary" asp-controller="Users" asp-action="Create"><i class="bi bi-person-plus"></i> Create user</a> }
<section class="admin-card">
    <div class="directory-toolbar">
        <form method="get" class="directory-filter-form">
            <div class="directory-search"><i class="bi bi-search"></i><input class="form-control" name="q" value="@ViewBag.Query" placeholder="Search name, email or username" /></div>
            <select class="form-select" name="companyId" asp-items="ViewBag.Companies"><option value="">All tenants</option></select>
            <button class="btn btn-primary">Apply filters</button>
            <a class="btn btn-outline" asp-action="Users">Clear</a>
        </form>
        <span class="text-muted small">@Model.Count result(s)</span>
    </div>
    <div class="table-responsive"><table class="table align-middle mb-0"><thead><tr><th>User</th><th>Tenants</th><th>Groups</th><th>Status</th><th></th></tr></thead><tbody>
    @if(Model.Count == 0){<tr><td colspan="5" class="text-center py-5"><i class="bi bi-person-x fs-2 text-muted"></i><p class="text-muted mt-2 mb-0">No users match these filters.</p></td></tr>}
    @foreach(var user in Model){<tr><td><div class="directory-identity"><span class="directory-avatar">@((string.IsNullOrWhiteSpace(user.DisplayName) ? "?" : user.DisplayName[..1]).ToUpperInvariant())</span><div><strong>@user.DisplayName</strong><div class="text-muted small">@user.Email</div></div></div></td><td><strong>@user.CompanyCount</strong><div class="text-muted small text-truncate directory-company-list" title="@user.Companies">@(string.IsNullOrWhiteSpace(user.Companies)?"Not assigned":user.Companies)</div></td><td>@user.GroupCount</td><td><span class="badge @(user.IsBlocked?"text-bg-secondary":"text-bg-success")">@(user.IsBlocked?"Blocked":"Active")</span></td><td class="text-end"><a class="btn btn-sm btn-outline-primary" asp-controller="Users" asp-action="Edit" asp-route-id="@user.Id">Manage <i class="bi bi-arrow-right"></i></a></td></tr>}
    </tbody></table></div>
</section>
