@model IReadOnlyList<Auth2Demo.Application.Services.Admin.DirectoryGroupRowData>
@{ ViewData["Title"] = "Directory groups"; }
@section AdminHeader {
    <span class="admin-page-kicker"><i class="bi bi-collection"></i> DIRECTORY</span>
    <h1>Groups</h1>
    <p>Manage tenant-scoped groups used for scalable enterprise application assignment.</p>
}
@section AdminActions { <a class="btn btn-outline" asp-controller="Companies" asp-action="Index"><i class="bi bi-plus-circle"></i> Create from a tenant</a> }
<section class="admin-card">
    <div class="directory-toolbar"><form method="get" class="directory-filter-form"><div class="directory-search"><i class="bi bi-search"></i><input class="form-control" name="q" value="@ViewBag.Query" placeholder="Search group name or description" /></div><select class="form-select" name="companyId" asp-items="ViewBag.Companies"><option value="">All tenants</option></select><button class="btn btn-primary">Apply filters</button><a class="btn btn-outline" asp-action="Groups">Clear</a></form><span class="text-muted small">@Model.Count result(s)</span></div>
    <div class="table-responsive"><table class="table align-middle mb-0"><thead><tr><th>Group</th><th>Tenant</th><th>Members</th><th>Application assignments</th><th>Status</th><th></th></tr></thead><tbody>
    @if(Model.Count==0){<tr><td colspan="6" class="text-center py-5"><i class="bi bi-collection fs-2 text-muted"></i><p class="text-muted mt-2 mb-0">No groups match these filters.</p></td></tr>}
    @foreach(var group in Model){<tr><td><strong>@group.Name</strong><div class="text-muted small">@(group.Description??"No description")</div></td><td><span class="badge text-bg-light">@group.CompanyName</span></td><td>@group.MemberCount</td><td>@group.ApplicationAssignmentCount</td><td><span class="badge @(group.IsEnabled?"text-bg-success":"text-bg-secondary")">@(group.IsEnabled?"Active":"Disabled")</span></td><td class="text-end"><a class="btn btn-sm btn-outline-primary" asp-action="Group" asp-route-id="@group.Id">Manage <i class="bi bi-arrow-right"></i></a></td></tr>}
    </tbody></table></div>
</section>
