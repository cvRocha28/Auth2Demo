@model Auth2Demo.Application.Services.Admin.EnterpriseAssignmentPageData
@using Auth2Demo.Domain.Identity
@{ ViewData["Title"]="Users and groups"; var users=Model.Principals.Where(x=>x.Type==EnterpriseAssignmentType.User); var groups=Model.Principals.Where(x=>x.Type==EnterpriseAssignmentType.Group); }
@section AdminHeader {<span class="admin-page-kicker"><i class="bi bi-person-check"></i> ENTERPRISE APPLICATION</span><h1>Users and groups</h1><p>Control explicit assignments and application roles for <strong>@Model.ApplicationName</strong>.</p><div class="admin-page-meta"><span><code>@Model.ClientId</code></span><span>@Model.Assignments.Count assignment(s)</span><span>@Model.Roles.Count role(s)</span></div>}
@section AdminActions {<a class="btn btn-outline" asp-controller="EnterpriseApplications" asp-action="Edit" asp-route-id="@Model.ApplicationId"><i class="bi bi-arrow-left"></i> Application configuration</a>}
@if(TempData["Success"] is string ok){<div class="alert alert-success">@ok</div>}@if(TempData["Error"] is string err){<div class="alert alert-danger">@err</div>}
<div class="row g-4"><div class="col-xl-8"><section class="admin-card"><div class="admin-card-header"><div><strong><i class="bi bi-person-lines-fill"></i> Current assignments</strong><span>Direct user and group assignments are evaluated before token issuance.</span></div></div><div class="table-responsive"><table class="table align-middle mb-0"><thead><tr><th>Principal</th><th>Tenant</th><th>Role</th><th>Status</th><th></th></tr></thead><tbody>@if(Model.Assignments.Count==0){<tr><td colspan="5" class="text-center py-5 text-muted">No assignments. Users in tenants requiring assignment will be denied.</td></tr>}@foreach(var a in Model.Assignments){<tr><td><strong>@a.PrincipalName</strong><div class="small text-muted"><i class="bi @(a.PrincipalType==EnterpriseAssignmentType.Group?"bi-people":"bi-person")"></i> @a.PrincipalType</div></td><td>@a.CompanyName</td><td>@(a.RoleName??"Default access")</td><td><span class="badge @(a.IsEnabled?"text-bg-success":"text-bg-secondary")">@(a.IsEnabled?"Active":"Disabled")</span></td><td class="text-end"><form asp-action="Remove" method="post" data-confirm="Remove this assignment?">@Html.AntiForgeryToken()<input type="hidden" name="applicationId" value="@Model.ApplicationId"/><input type="hidden" name="assignmentId" value="@a.Id"/><button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button></form></td></tr>}</tbody></table></div></section></div>
<div class="col-xl-4"><section class="admin-card mb-4"><div class="admin-card-header"><div><strong>New assignment</strong><span>Assign an authorized tenant user or group.</span></div></div><form asp-action="Assign" method="post" class="p-4" id="assignForm">@Html.AntiForgeryToken()<input type="hidden" name="applicationId" value="@Model.ApplicationId"/><div class="mb-3"><label class="form-label">Principal</label><select class="form-select" name="principalComposite" id="principalComposite" required><option value="">Select user or group</option><optgroup label="Users">@foreach(var p in users){<option value="@p.CompanyId|1|@p.Id">@p.CompanyName — @p.Name</option>}</optgroup><optgroup label="Groups">@foreach(var p in groups){<option value="@p.CompanyId|2|@p.Id">@p.CompanyName — @p.Name</option>}</optgroup></select><input type="hidden" name="companyId" id="companyId"/><input type="hidden" name="principalType" id="principalType"/><input type="hidden" name="principalId" id="principalId"/></div><div class="mb-3"><label class="form-label">Application role</label><select class="form-select" name="roleId"><option value="">Default access</option>@foreach(var r in Model.Roles.Where(x=>x.IsEnabled)){<option value="@r.Id">@r.Name (@r.Value)</option>}</select></div><button class="btn btn-primary w-100"><i class="bi bi-person-plus"></i> Assign</button></form></section>
<section class="admin-card"><div class="admin-card-header"><div><strong>Application roles</strong><span>Roles are emitted in tokens for assigned principals.</span></div></div><div class="p-4">@foreach(var role in Model.Roles){<div class="border rounded-3 p-2 mb-2"><strong>@role.Name</strong> <code>@role.Value</code><div class="small text-muted">@role.Description</div></div>}<form asp-action="SaveRole" method="post" class="mt-3">@Html.AntiForgeryToken()<input type="hidden" name="applicationId" value="@Model.ApplicationId"/><div class="mb-2"><input class="form-control" name="name" placeholder="Role name" required maxlength="160"/></div><div class="mb-2"><input class="form-control" name="value" placeholder="Token value, e.g. Manager" required maxlength="120"/></div><div class="mb-2"><textarea class="form-control" name="description" placeholder="Description" maxlength="500"></textarea></div><button class="btn btn-outline-primary w-100"><i class="bi bi-plus-circle"></i> Add role</button></form></div></section></div></div>


@section Scripts {
    <script src="~/js/pages/enterpriseassignments-index.js" asp-append-version="true" defer></script>
}
