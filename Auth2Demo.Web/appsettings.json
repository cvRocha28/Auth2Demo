{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=Auth2Demo;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "AuthenticationServer": {
    "Issuer": "https://localhost:7241/",
    "SeedDefaultClients": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "SecurityHeaders": {
    "Csp": {
      "FormActionSources": [
        "https://accounts.google.com",
        "https://login.microsoftonline.com",
        "https://login.live.com"
      ],
      "FrameSources": [
        "https://accounts.google.com",
        "https://login.microsoftonline.com",
        "https://login.live.com"
      ]
    }
  }
}
